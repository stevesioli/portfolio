# Base path the site is deployed under. Leave as "/" for a root deploy
# (Netlify, Vercel, Cloudflare Pages, custom domain, S3+CloudFront).
# For a GitHub Pages *project* page (username.github.io/repo-name/),
# set this to "/repo-name/" and rebuild.
VITE_BASE_PATH=/

# Optional: form-submission endpoint for the contact remote (e.g. a
# Formspree/Web3Forms endpoint, or your own serverless function).
# If unset, the contact form falls back to a mailto: link.
VITE_CONTACT_FORM_ENDPOINT=
